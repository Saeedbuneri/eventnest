# URL of the Express backend (set to your Render/Railway/EC2 URL in production)
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Set to "true" to force mock/demo data without a running backend.
# Enable this when deploying the frontend to Vercel without a backend.
NEXT_PUBLIC_USE_MOCK=false

# Stripe publishable key (browser-safe)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
