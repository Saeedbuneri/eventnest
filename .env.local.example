# ─── Database ────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string
# Get it from: https://cloud.mongodb.com → Clusters → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/eventnest?retryWrites=true&w=majority

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Random 32+ char secret — generate with: openssl rand -base64 32
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars

# ─── Stripe (optional — only needed for real payments) ────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# ─── App URL (set this on Vercel to your deployment URL) ─────────────────────
# Leave as /api for local dev — api.js auto-detects origin in the browser
NEXT_PUBLIC_API_URL=http://localhost:3000/api
